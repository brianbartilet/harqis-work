# ── IDE / editor ─────────────────────────────────────────────────────────────
.idea
.claude/settings.local.json

# ── Secrets / env files ──────────────────────────────────────────────────────
.env/*
**/.env
**/.env.*

# ── Per-machine deploy override (gitignored sibling of machines.toml) ────────
machines.local.toml

# ── Stateful container data (HARQIS_DATA_ROOT bind: rabbitmq/n8n/ES state) ───
# Runtime-only — regenerated by the containers. The RabbitMQ .erlang.cookie
# in particular is a node secret and must never be committed.
.harqis-data/

# ── Migration reference files (working-tree only — never committed) ──────────
# Drop-in "after" snapshots used while migrating values out of apps.env into
# the per-machine TOMLs. See docs/info/WORKER-CONFIG-DISTRIBUTION.md §3.
.env/apps.env.new
/machines.toml.new
/machines.local.toml.new

# ── Python virtualenv ────────────────────────────────────────────────────────
.venv
venv

# ── Runtime state (PID files, logs, screenshots, ad-hoc data) ────────────────
*pid.*
.run/*.pid
*.log*
logs/
screenshots/
data/

# ── Build / packaging artifacts ──────────────────────────────────────────────
*.bak*
*.dat*
*.dir*
*.zip*
*.tgz
*.egg
*.egg-info/

# ── Generated mapping files (regenerated by scripts/agents/run_agent_prompt.py) ─
/workflows.mapping
/scripts.mapping

# ── Frontend task registry (regenerated by frontend/generate_registry.py) ────
/frontend/registry.json

# ── MCP ──────────────────────────────────────────────────────────────────────
mcp/claude_desktop_config.json

# ── Celery ───────────────────────────────────────────────────────────────────
*celerybeat-schedule.db*

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]

# ── OwnTracks ────────────────────────────────────────────────────────────────
apps/own_tracks/recorder_store/
/apps/own_tracks/mosquitto/data/mosquitto.db

# ── Hermes (agent runtime — local per-machine state) ─────────────────────────
.hermes/

# ── OpenClaw (deprecated — superseded by Hermes; kept ignored for legacy state)
.openclaw/
