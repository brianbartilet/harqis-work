# ── IDE / editor ─────────────────────────────────────────────────────────────
.idea
.claude/settings.local.json

# ── Secrets / env files ──────────────────────────────────────────────────────
.env/*
**/.env
**/.env.*

# ── Per-machine deploy override (gitignored sibling of machines.toml) ────────
machines.local.toml

# ── Python virtualenv ────────────────────────────────────────────────────────
.venv
venv

# ── Runtime state (PID files, logs, screenshots, ad-hoc data) ────────────────
*pid.*
*.log*
logs/
screenshots/
data/

# ── Build / packaging artifacts ──────────────────────────────────────────────
*.bak*
*.dat*
*.dir*
*.zip*
*.tgz
*.egg
*.egg-info/

# ── Generated mapping files (regenerated by run_agent_prompt.py) ─────────────
/workflows.mapping
/scripts.mapping

# ── MCP ──────────────────────────────────────────────────────────────────────
mcp/claude_desktop_config.json

# ── Celery ───────────────────────────────────────────────────────────────────
celerybeat-schedule.db

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]

# ── OwnTracks ────────────────────────────────────────────────────────────────
apps/own_tracks/recorder_store/
/apps/own_tracks/mosquitto/data/mosquitto.db

# ── OpenClaw ─────────────────────────────────────────────────────────────────
.openclaw/*
!.openclaw/workspace
!.openclaw/workspace/**
/.openclaw/workspace/
